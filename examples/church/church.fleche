# Church numerals — closure-heavy, tests capture and GC
# to_int(eight) = 8

define zero as f -> x -> x

define succ as n -> f -> x -> f (n f x)

define add as a -> b -> f -> x -> a f (b f x)

define to_int as n -> n (x -> builtin add x 1) 0

define main as
  let two = succ (succ zero) in
  let four = add two two in
  let eight = add four four in
  to_int eight
