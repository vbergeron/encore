# Count leaves in a binary tree
# count(Node(Node(Leaf, Leaf), Node(Leaf, Node(Leaf, Leaf)))) = 5

data Leaf | Node(left, right)

define count as t ->
  match t
  | Leaf -> 1
  | Node(l, r) ->
    let a = count l in
    let b = count r in
    builtin add a b
  end

define main as
  count Node(Node(Leaf, Leaf), Node(Leaf, Node(Leaf, Leaf)))
